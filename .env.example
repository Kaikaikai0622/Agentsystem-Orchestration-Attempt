# AI API Configuration
# Copy this file to .env and fill in your actual API keys

# Worker API (for routing, data cleaning, simple tasks)
# Recommended: GPT-4o-mini, GLM-4-Flash, or similar fast/cheap models
WORKER_API_KEY=your_worker_api_key_here
WORKER_API_BASE=https://api.example.com/v1
WORKER_MODEL=gpt-4o-mini
WORKER_TEMPERATURE=0.1

# Analyst API (for deep analysis, market intelligence, report generation)
# Recommended: GPT-4o, Claude 3.5, GLM-4, or similar powerful models
ANALYST_API_KEY=your_analyst_api_key_here
ANALYST_API_BASE=https://api.example.com/v1
ANALYST_MODEL=gpt-4o
ANALYST_TEMPERATURE=0.7

# MiniMax API (OpenAI-compatible, used by reviewer profile)
MINIMAXI_API_KEY=your_minimaxi_api_key_here

# Moonshot API (used by worker profile via OpenAI SDK)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Legacy compatibility (deprecated): if MOONSHOT_API_KEY is not set,
# the system will fall back to this variable for worker temporarily.
# ANTHROPIC_API_KEY=your_legacy_worker_key_here

# Anthropic-compatible API (reviewer -> MiniMax)
ANTHROPIC_REVIEWER_API_KEY=your_anthropic_reviewer_key_here

# Timeout settings (seconds)
API_TIMEOUT=60
